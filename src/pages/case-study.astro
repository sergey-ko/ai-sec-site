---
import Base from '@fce/shared/layouts/Base.astro';
import Nav from '@fce/shared/components/Nav.astro';
import Badge from '@fce/shared/components/Badge.astro';
import Card from '@fce/shared/components/Card.astro';
import Button from '@fce/shared/components/Button.astro';
import Footer from '@fce/shared/components/Footer.astro';
import FindingCard from '../components/FindingCard.astro';
import { navLinks, footerLinks, navCta, url } from '../lib/links';
import '../styles/theme.css';
---

<Base
  title="91 Findings Across 108K+ GitHub Stars \u2014 AI-Sec"
  description="Real security audit case studies: maybe-finance (35K stars), Documenso (8K stars), Hoppscotch (65K stars). 91 findings including plaintext credentials, commented-out encryption, and IDORs."
>
  <Nav logo="AI-Sec" homeHref={url('/')} links={navLinks} ctaText={navCta.text} ctaHref={navCta.href} />

  <!-- Hero -->
  <section class="py-24 md:py-32" style={`background: var(--gradient-hero)`}>
    <div class="max-w-6xl mx-auto px-6 text-center">
      <Badge text="Public Audit Case Studies" class="mb-8" />
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold leading-tight max-w-4xl mx-auto">
        91 findings across 3 projects<br />with 108K+ GitHub stars.
      </h1>
      <p class="text-lg sm:text-xl text-[var(--text-secondary)] mt-6 max-w-3xl mx-auto leading-relaxed">
        We audited popular open-source projects using the same AI-powered methodology available in our free tool and consulting engagements. Here's what we found.
      </p>
      <div class="mt-8">
        <Button href={url('/contact')} variant="primary" size="lg">Book Your Audit &rarr;</Button>
      </div>
    </div>
  </section>

  <!-- Summary Stats -->
  <section class="py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-secondary)]">
          <p class="text-4xl md:text-5xl font-bold text-[var(--accent-primary)]">91</p>
          <p class="text-sm text-[var(--text-muted)] mt-2">Total findings</p>
        </div>
        <div class="text-center p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-secondary)]">
          <p class="text-4xl md:text-5xl font-bold text-[var(--accent-primary)]">3</p>
          <p class="text-sm text-[var(--text-muted)] mt-2">Projects audited</p>
        </div>
        <div class="text-center p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-secondary)]">
          <p class="text-4xl md:text-5xl font-bold text-[var(--accent-primary)]">108K+</p>
          <p class="text-sm text-[var(--text-muted)] mt-2">Combined GitHub stars</p>
        </div>
        <div class="text-center p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-secondary)]">
          <p class="text-4xl md:text-5xl font-bold text-[var(--accent-primary)]">100%</p>
          <p class="text-sm text-[var(--text-muted)] mt-2">Findings with fix guidance</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Audit 1: maybe-finance -->
  <section class="py-24 md:py-32 bg-[var(--bg-secondary)]" id="maybe-finance">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-12">
        <div>
          <Badge text="Audit #1" class="mb-4" />
          <h2 class="text-3xl md:text-5xl font-bold">maybe-finance</h2>
          <p class="text-[var(--text-secondary)] mt-2 text-lg">Open-source personal finance app</p>
        </div>
        <div class="flex gap-6 mt-4 md:mt-0">
          <div class="text-center">
            <p class="text-2xl font-bold text-[var(--accent-primary)]">35K</p>
            <p class="text-xs text-[var(--text-muted)]">GitHub stars</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-bold text-[var(--accent-primary)]">Ruby / Rails</p>
            <p class="text-xs text-[var(--text-muted)]">Stack</p>
          </div>
        </div>
      </div>

      <div class="mb-8">
        <p class="text-[var(--text-secondary)] text-lg leading-relaxed max-w-3xl">
          maybe-finance is a popular open-source personal finance app that connects to bank accounts and aggregates financial data. Our audit revealed critical credential storage issues and access control flaws in an application that handles some of the most sensitive data users have: their bank accounts.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <FindingCard
          severity="CRITICAL"
          title="Plaintext Bank Credentials in Configuration"
          cvss="9.1"
          owasp="A02:2021"
          cwe="CWE-312"
          description="Bank account credentials including routing numbers, account numbers, and API keys for financial providers are stored in plaintext configuration files accessible to the application runtime. No encryption at rest, no secrets management."
          fix="Move credentials to a secrets manager (Vault, AWS Secrets Manager). Never store financial credentials in config files, environment variables, or source code."
        />
        <FindingCard
          severity="HIGH"
          title="Missing Access Control on Financial Data Endpoints"
          cvss="7.5"
          owasp="A01:2021"
          cwe="CWE-862"
          description="Several API endpoints that return financial transaction data and account balances do not properly verify that the requesting user owns the account being queried. An authenticated user could potentially access other users' financial data."
          fix="Implement consistent ownership validation on all financial data endpoints. Verify account.user_id === current_user.id before returning any data."
        />
      </div>

      <div class="flex flex-wrap gap-4 text-sm">
        <a href="https://github.com/sergey-ko/ai-sec/blob/main/examples/maybe-finance-web-audit.md" target="_blank" rel="noopener noreferrer" class="text-[var(--accent-primary)] hover:underline">Web audit report &rarr;</a>
        <a href="https://github.com/sergey-ko/ai-sec/blob/main/examples/maybe-finance-cicd-audit.md" target="_blank" rel="noopener noreferrer" class="text-[var(--accent-primary)] hover:underline">CI/CD audit report &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Audit 2: Documenso -->
  <section class="py-24 md:py-32" id="documenso">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-12">
        <div>
          <Badge text="Audit #2" class="mb-4" />
          <h2 class="text-3xl md:text-5xl font-bold">Documenso</h2>
          <p class="text-[var(--text-secondary)] mt-2 text-lg">Open-source e-signing platform</p>
        </div>
        <div class="flex gap-6 mt-4 md:mt-0">
          <div class="text-center">
            <p class="text-2xl font-bold text-[var(--accent-primary)]">8K</p>
            <p class="text-xs text-[var(--text-muted)]">GitHub stars</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-bold text-[var(--accent-primary)]">TypeScript / Next.js</p>
            <p class="text-xs text-[var(--text-muted)]">Stack</p>
          </div>
        </div>
      </div>

      <div class="mb-8">
        <p class="text-[var(--text-secondary)] text-lg leading-relaxed max-w-3xl">
          Documenso is an open-source alternative to DocuSign for e-signing documents. The core value proposition is trust and legal validity of signed documents. Our audit found that the very mechanism ensuring document integrity had been disabled.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <FindingCard
          severity="CRITICAL"
          title="Encryption Validation Commented Out in Signing Flow"
          cvss="8.8"
          owasp="A02:2021"
          cwe="CWE-327"
          description="The document signing flow contains encryption validation logic that was commented out during development and never re-enabled. This means signed documents can be tampered with after signing without detection, undermining the entire legal validity of e-signatures on the platform."
          fix="Re-enable encryption validation in the signing flow. Add integration tests that verify validation is active and cannot be silently disabled. Consider a CI check that flags commented-out security code."
        />
        <FindingCard
          severity="HIGH"
          title="Insufficient Document Access Controls"
          cvss="7.2"
          owasp="A01:2021"
          cwe="CWE-639"
          description="Document sharing links use predictable identifiers. While authentication is required, the authorization check does not properly verify the user was invited as a signer or viewer. Users with valid accounts can access documents they weren't meant to see."
          fix="Replace predictable document IDs with cryptographically random tokens for sharing. Verify the requesting user is explicitly listed as a signer or viewer before granting access."
        />
      </div>

      <div class="flex flex-wrap gap-4 text-sm">
        <a href="https://github.com/sergey-ko/ai-sec/blob/main/examples/documenso-web-audit.md" target="_blank" rel="noopener noreferrer" class="text-[var(--accent-primary)] hover:underline">Web audit report &rarr;</a>
        <a href="https://github.com/sergey-ko/ai-sec/blob/main/examples/documenso-cicd-audit.md" target="_blank" rel="noopener noreferrer" class="text-[var(--accent-primary)] hover:underline">CI/CD audit report &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Audit 3: Hoppscotch -->
  <section class="py-24 md:py-32 bg-[var(--bg-secondary)]" id="hoppscotch">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-12">
        <div>
          <Badge text="Audit #3" class="mb-4" />
          <h2 class="text-3xl md:text-5xl font-bold">Hoppscotch</h2>
          <p class="text-[var(--text-secondary)] mt-2 text-lg">Open-source API development platform</p>
        </div>
        <div class="flex gap-6 mt-4 md:mt-0">
          <div class="text-center">
            <p class="text-2xl font-bold text-[var(--accent-primary)]">65K</p>
            <p class="text-xs text-[var(--text-muted)]">GitHub stars</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-bold text-[var(--accent-primary)]">TypeScript / Vue</p>
            <p class="text-xs text-[var(--text-muted)]">Stack</p>
          </div>
        </div>
      </div>

      <div class="mb-8">
        <p class="text-[var(--text-secondary)] text-lg leading-relaxed max-w-3xl">
          Hoppscotch is one of the most popular open-source API development tools. Users save API requests with authentication tokens, production API keys, and secrets. Our audit found that these saved credentials were accessible to other users through an IDOR vulnerability.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <FindingCard
          severity="CRITICAL"
          title="IDOR: Any User Can Read Other Users' Saved API Keys"
          cvss="8.6"
          owasp="A01:2021"
          cwe="CWE-639"
          description="The user environments API endpoint returns saved API keys and authentication tokens for any environment ID without verifying that the requesting user owns that environment. An attacker can enumerate environment IDs to access production secrets, API keys, and auth tokens stored by other users."
          fix="Add ownership validation: verify req.user.id matches the environment's ownerUid before returning data. Apply the same pattern to all user-scoped resources."
        />
        <FindingCard
          severity="HIGH"
          title="GraphQL Query Depth Not Limited"
          cvss="7.5"
          owasp="A04:2021"
          cwe="CWE-400"
          description="The GraphQL API does not limit query depth or complexity. An attacker can craft deeply nested queries that cause exponential resource consumption on the server, leading to denial of service. This affects all users of the shared platform."
          fix="Implement query depth limiting (max 10-15 levels) and query complexity analysis. Use graphql-depth-limit or similar middleware. Rate-limit by query complexity score."
        />
      </div>

      <div class="flex flex-wrap gap-4 text-sm">
        <a href="https://github.com/sergey-ko/ai-sec/blob/main/examples/hoppscotch-web-audit.md" target="_blank" rel="noopener noreferrer" class="text-[var(--accent-primary)] hover:underline">Web audit report &rarr;</a>
        <a href="https://github.com/sergey-ko/ai-sec/blob/main/examples/hoppscotch-cicd-audit.md" target="_blank" rel="noopener noreferrer" class="text-[var(--accent-primary)] hover:underline">CI/CD audit report &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Production Fintech Reference -->
  <section class="py-24 md:py-32">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl md:text-5xl font-bold mb-8">Plus: 87+ findings on production fintech.</h2>
      <p class="text-[var(--text-secondary)] text-lg leading-relaxed mb-8">
        Beyond these public audits, AI-Sec's methodology was developed and battle-tested on a live, VARA-regulated cryptocurrency exchange over two full audit iterations. That engagement produced 87+ findings including critical authentication bypasses, access control failures, and compliance gaps.
      </p>

      <div class="grid sm:grid-cols-3 gap-6 mb-8">
        <div class="text-center p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-secondary)]">
          <p class="text-3xl font-bold text-[var(--accent-primary)]">87+</p>
          <p class="text-sm text-[var(--text-muted)] mt-1">Findings</p>
        </div>
        <div class="text-center p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-secondary)]">
          <p class="text-3xl font-bold text-[var(--accent-primary)]">2</p>
          <p class="text-sm text-[var(--text-muted)] mt-1">Full iterations</p>
        </div>
        <div class="text-center p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-secondary)]">
          <p class="text-3xl font-bold text-[var(--accent-primary)]">VARA</p>
          <p class="text-sm text-[var(--text-muted)] mt-1">Regulated</p>
        </div>
      </div>

      <p class="text-sm text-[var(--text-muted)] leading-relaxed">
        Details of the production fintech engagement are confidential. The methodology, tooling, and audit depth are identical to what you get with AI-Sec consulting.
      </p>
    </div>
  </section>

  <!-- Methodology -->
  <section class="py-24 md:py-32 bg-[var(--bg-secondary)]">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl md:text-5xl font-bold mb-8">Our methodology.</h2>
      <p class="text-[var(--text-secondary)] text-lg leading-relaxed mb-12">
        The same approach is used across all engagements &mdash; from the free open-source tool to enterprise consulting.
      </p>
      <div class="space-y-8">
        <div class="flex gap-6">
          <div class="flex-shrink-0">
            <span class="flex items-center justify-center w-10 h-10 rounded-full bg-[var(--bg-tertiary)] border border-[var(--border)] text-[var(--accent-primary)] font-mono font-bold text-sm">1</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold mb-2">Full codebase ingestion</h3>
            <p class="text-[var(--text-secondary)] leading-relaxed">AI reads the entire codebase &mdash; frontend, backend, API layer, infrastructure configs &mdash; and builds a holistic understanding of architecture, data flows, and trust boundaries.</p>
          </div>
        </div>
        <div class="flex gap-6">
          <div class="flex-shrink-0">
            <span class="flex items-center justify-center w-10 h-10 rounded-full bg-[var(--bg-tertiary)] border border-[var(--border)] text-[var(--accent-primary)] font-mono font-bold text-sm">2</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold mb-2">OWASP ASVS L2 systematic audit</h3>
            <p class="text-[var(--text-secondary)] leading-relaxed">Every relevant control in the OWASP ASVS L2 checklist (286 verification requirements across 14 categories) is evaluated. Findings are tagged with CVSS severity scores and CWE identifiers.</p>
          </div>
        </div>
        <div class="flex gap-6">
          <div class="flex-shrink-0">
            <span class="flex items-center justify-center w-10 h-10 rounded-full bg-[var(--bg-tertiary)] border border-[var(--border)] text-[var(--accent-primary)] font-mono font-bold text-sm">3</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold mb-2">Architectural reasoning</h3>
            <p class="text-[var(--text-secondary)] leading-relaxed">Not pattern matching. The AI reasons about auth flows, data access patterns, trust boundary crossings, and business logic. This catches IDORs, broken authentication, and logic flaws that scanners miss.</p>
          </div>
        </div>
        <div class="flex gap-6">
          <div class="flex-shrink-0">
            <span class="flex items-center justify-center w-10 h-10 rounded-full bg-[var(--bg-tertiary)] border border-[var(--border)] text-[var(--accent-primary)] font-mono font-bold text-sm">4</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold mb-2">Actionable reporting</h3>
            <p class="text-[var(--text-secondary)] leading-relaxed">Every finding includes severity (CVSS), OWASP category, CWE identifier, detailed description, reproduction steps, and code-level fix guidance. Not a 200-page PDF &mdash; actionable output you can hand to your dev team or AI coding agent.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-24 md:py-32" style={`background: var(--gradient-hero)`}>
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold">Your codebase deserves the same analysis.</h2>
      <p class="text-[var(--text-secondary)] mt-4 text-lg">
        Start free with the open-source tool, or book a call to scope your audit. Same methodology that found 91 findings across 108K+ GitHub stars.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <Button href="https://github.com/sergey-ko/ai-sec" variant="primary" size="lg">Try the Free Tool &rarr;</Button>
        <Button href={url('/contact')} variant="secondary" size="lg">Book a Call</Button>
      </div>
    </div>
  </section>

  <Footer productName="AI-Sec" links={footerLinks} />
</Base>
