---
import Base from '@fce/shared/layouts/Base.astro';
import Nav from '@fce/shared/components/Nav.astro';
import Badge from '@fce/shared/components/Badge.astro';
import Button from '@fce/shared/components/Button.astro';
import Footer from '@fce/shared/components/Footer.astro';
import { navLinks, footerLinks, navCta, url } from '../lib/links';
import '../styles/theme.css';
---

<Base
  title="AI-Sec Platform — Coming Soon"
  description="Self-service AI security platform with multi-step audit workflows, attack path chaining, and continuous monitoring. Join the waitlist."
>
  <Nav logo="AI-Sec" homeHref={url('/')} links={navLinks} ctaText={navCta.text} ctaHref={navCta.href} />

  <!-- Hero -->
  <section class="py-24 md:py-32" style="background: var(--gradient-hero)">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <Badge text="Coming Soon" class="mb-8" />
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-semibold leading-tight tracking-tight">
        The free tool scans.<br />The platform hunts.
      </h1>
      <p class="text-lg sm:text-xl text-[var(--text-secondary)] mt-6 max-w-2xl mx-auto leading-relaxed">
        Multi-step hardened audit workflows. Attack path chaining. Continuous monitoring on every PR. Fix verification. $299/mo.
      </p>
    </div>
  </section>

  <!-- What it will do -->
  <section class="py-24 md:py-32">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-2xl md:text-3xl font-semibold tracking-tight mb-8">What the platform adds over the free tool.</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <h3 class="font-semibold text-[var(--color-saas)] mb-2">Multi-step workflows</h3>
          <p class="text-sm text-[var(--text-secondary)] leading-relaxed">The free tool does a single-pass scan. The platform runs multi-step workflows &mdash; scan, validate, re-test from different angles, chain attack paths across modules.</p>
        </div>
        <div>
          <h3 class="font-semibold text-[var(--color-saas)] mb-2">Continuous monitoring</h3>
          <p class="text-sm text-[var(--text-secondary)] leading-relaxed">Scan on every PR automatically. Track security posture over time. Get alerted when new vulnerabilities are introduced.</p>
        </div>
        <div>
          <h3 class="font-semibold text-[var(--color-saas)] mb-2">Fix verification</h3>
          <p class="text-sm text-[var(--text-secondary)] leading-relaxed">After you fix a finding, the platform re-tests to confirm the fix actually works. No more "we think we fixed it."</p>
        </div>
        <div>
          <h3 class="font-semibold text-[var(--color-saas)] mb-2">Team dashboard</h3>
          <p class="text-sm text-[var(--text-secondary)] leading-relaxed">Track findings, fixes, and trends across your team. See your security posture improve over time. Export for compliance.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Waitlist form -->
  <section class="py-24 md:py-32 bg-[var(--bg-secondary)]">
    <div class="max-w-md mx-auto px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-semibold tracking-tight mb-4">Get early access.</h2>
      <p class="text-[var(--text-secondary)] mb-8">
        Leave your email and we'll notify you when the platform launches. Early adopters get priority access and a discount.
      </p>
      <form id="waitlist-form" class="space-y-4">
        <input
          type="email"
          required
          placeholder="you@company.com"
          class="w-full px-4 py-3 rounded-lg bg-[var(--bg-primary)] border border-[var(--border)] text-[var(--text-primary)] placeholder-[var(--text-muted)] focus:outline-none focus:border-[var(--color-saas)] transition-colors"
        />
        <button
          type="submit"
          class="w-full px-6 py-3 rounded-lg font-medium bg-[var(--color-saas)] text-black hover:opacity-90 transition-opacity"
        >
          Join Waitlist &rarr;
        </button>
      </form>
      <div id="waitlist-success" class="hidden py-8">
        <div class="text-[var(--color-saas)] text-4xl mb-4">&#10003;</div>
        <h3 class="text-xl font-bold mb-2">You're on the list!</h3>
        <p class="text-[var(--text-secondary)]">We'll email you when the platform launches.</p>
      </div>
    </div>
  </section>

  <!-- Meanwhile -->
  <section class="py-24 md:py-32">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-semibold tracking-tight mb-4">Available today.</h2>
      <p class="text-[var(--text-secondary)] mb-8">
        Don't wait for the platform. Start securing your code right now.
      </p>
      <div class="grid md:grid-cols-2 gap-8 max-w-2xl mx-auto">
        <div class="rounded-xl border border-[var(--color-opensource)]/30 bg-[var(--bg-secondary)] p-6 text-center">
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-[var(--color-opensource)]">Free</span>
          <h3 class="text-lg font-semibold mt-2">Open-Source Tool</h3>
          <p class="text-sm text-[var(--text-secondary)] mt-2 mb-4">Clone the repo, run /audit, get findings. ~60-70% coverage.</p>
          <a href="https://github.com/sergey-ko/ai-sec" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm text-[var(--color-opensource)] hover:underline font-medium">View on GitHub &rarr;</a>
        </div>
        <div class="rounded-xl border border-[var(--color-consulting)]/30 bg-[var(--bg-secondary)] p-6 text-center">
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-[var(--color-consulting)]">From $3,500</span>
          <h3 class="text-lg font-semibold mt-2">Consulting</h3>
          <p class="text-sm text-[var(--text-secondary)] mt-2 mb-4">AI-powered red team. Expert review. Compliance-ready reports.</p>
          <a href={url('/contact')} class="inline-flex items-center text-sm text-[var(--color-consulting)] hover:underline font-medium">Book a call &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <Footer productName="AI-Sec" links={footerLinks} />
</Base>

<script>
  const form = document.getElementById('waitlist-form') as HTMLFormElement;
  const success = document.getElementById('waitlist-success');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    form.style.display = 'none';
    if (success) success.classList.remove('hidden');
  });
</script>
