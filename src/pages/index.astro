---
import Base from '@fce/shared/layouts/Base.astro';
import Nav from '@fce/shared/components/Nav.astro';
import Card from '@fce/shared/components/Card.astro';
import Terminal from '@fce/shared/components/Terminal.astro';
import Button from '@fce/shared/components/Button.astro';
import Footer from '@fce/shared/components/Footer.astro';
import TierCard from '../components/TierCard.astro';
import FindingCard from '../components/FindingCard.astro';
import AnimatedTerminal from '../components/AnimatedTerminal.astro';
import '../styles/theme.css';
import { navLinks, footerLinks, navCta, url } from '../lib/links';

const terminalLines = [
  '<span class="text-[var(--text-muted)]">$</span> ai-sec audit --repo github.com/maybe-finance/maybe',
  '',
  '<span class="text-[var(--color-opensource)]">&#10003;</span> Analyzing 847 files across 12 modules...',
  '',
  '<span class="text-[var(--text-muted)]">── RESULTS ──────────────────────────────────</span>',
  '<span class="text-[var(--color-error)] font-bold">  CRITICAL  4</span>   Plaintext credentials, broken access control',
  '<span class="text-red-400 font-bold">  HIGH      9</span>   Missing encryption, IDOR vulnerabilities',
  '<span class="text-[var(--color-warning)] font-bold">  MEDIUM   14</span>   Rate limiting, session management',
  '<span class="text-[var(--text-muted)] font-bold">  LOW       6</span>   Informational findings',
  '',
  '  Full report: ./audit-report.md',
];
---

<Base
  title="AI-Sec — AI Security from Free to Enterprise"
  description="Open-source AI security tools, self-service platform, and AI-powered consulting. 98 findings across 3 projects with 108K+ GitHub stars."
>
  <Nav logo="AI-Sec" homeHref={url('/')} links={navLinks} ctaText={navCta.text} ctaHref={navCta.href} />

  <!-- Hero -->
  <section class="min-h-[80vh] flex items-center py-24 md:py-32 bg-grid" style="background: var(--gradient-hero)">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <span class="inline-block text-xs font-mono font-medium text-[var(--text-muted)] tracking-wider uppercase mb-8">
        98 findings across 3 projects &middot; 108K+ GitHub stars
      </span>
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-normal text-[var(--text-primary)] leading-[1.1] max-w-4xl mx-auto" style="font-family: 'Instrument Serif', Georgia, serif">
        We think AI security should be free.
      </h1>
      <p class="text-xl md:text-2xl text-[var(--text-secondary)] mt-4 font-normal" style="font-family: 'Instrument Serif', Georgia, serif">
        We also think some problems need more than free can give.
      </p>
      <p class="text-base md:text-lg text-[var(--text-muted)] mt-8 max-w-2xl mx-auto leading-relaxed">
        Open-source tools for every developer. Self-service platform for growing teams. AI-powered consulting for when the stakes are real.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10">
        <a href="https://github.com/sergey-ko/ai-sec" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-6 py-3 rounded-lg font-medium border border-[var(--border)] text-[var(--text-primary)] hover:border-[var(--border-hover)] transition-colors">
          Clone the repo &mdash; it's free
        </a>
        <a href={url('/contact')} class="inline-flex items-center justify-center px-6 py-3 rounded-lg font-medium bg-white text-black hover:bg-white/90 transition-colors">
          Book a 30-min call &rarr;
        </a>
      </div>
      <!-- Animated terminal demo -->
      <div class="mt-16 max-w-2xl mx-auto">
        <AnimatedTerminal />
      </div>
    </div>
  </section>

  <!-- Tier 1: Open Source -->
  <TierCard
    tier="opensource"
    label="Open Source"
    headline="Our gift to make AI development safer."
    story="We believe every developer deserves access to AI security analysis. So we open-sourced our audit engine &mdash; the same technology that found 98 vulnerabilities across maybe-finance, Documenso, and Hoppscotch.<br /><br />It's not a teaser. It's not feature-gated. It runs in your IDE, analyzes your entire codebase, and finds real issues. Clone it, run it, ship safer code."
    features={[
      'Claude Code skill — run /audit in your IDE',
      '5 specialized agents (web, API, CI/CD, infra, mobile)',
      'OWASP Top 10 coverage',
      'Finds ~60-70% of what a full audit catches',
      'No account, no tracking, no strings',
    ]}
    proof="We audited 3 open-source projects with 108K+ combined GitHub stars and found 98 real vulnerabilities. The tool is real."
    ctaPrimary={{ text: 'View on GitHub →', href: 'https://github.com/sergey-ko/ai-sec' }}
    ctaSecondary={{ text: 'Read the audits →', href: url('/case-study') }}
  >
    <Terminal title="ai-sec audit" lines={terminalLines} />
  </TierCard>

  <!-- Tier 2: SaaS -->
  <TierCard
    tier="saas"
    label="Self-Service Platform"
    headline="The free tool scans. The platform hunts."
    story="A single-pass scan catches a lot. But real security requires orchestration.<br /><br />Our platform runs multi-step hardened workflows: it scans your codebase, identifies potential issues, then re-tests from different angles. It chains attack paths across modules. It retests after you fix. It monitors continuously on every PR.<br /><br />That orchestration is why it's not free &mdash; it's a fundamentally different kind of analysis."
    features={[
      'Multi-step audit workflows with retesting',
      'Attack path chaining across your codebase',
      'Continuous monitoring — scan on every PR',
      'Fix verification — confirm your patches work',
      'CI/CD integration (GitHub Actions, GitLab CI)',
      'Team dashboard with trend tracking',
    ]}
    pricingHint="$299/mo — launching soon"
    ctaPrimary={{ text: 'Join Waitlist →', href: url('/free-scan') }}
    ctaSecondary={{ text: 'See pricing →', href: url('/pricing') }}
  >
    <!-- Workflow visual with progress bar -->
    <div class="relative text-sm font-mono">
      <!-- Vertical connecting line -->
      <div class="absolute left-5 top-6 bottom-6 w-px bg-gradient-to-b from-[var(--color-saas)]/50 via-[var(--color-saas)]/30 to-[var(--color-saas)]/10"></div>

      <div class="space-y-5 relative">
        {[
          { step: '1', title: 'Initial scan', result: '27 potential findings', progress: 100 },
          { step: '2', title: 'Cross-reference & validate', result: '18 confirmed', progress: 67 },
          { step: '3', title: 'Chain attack paths', result: '3 critical chains found', progress: 100 },
          { step: '4', title: 'Generate fix guidance', result: 'Actionable report ready', progress: 100 },
        ].map(s => (
          <div class="flex items-start gap-4">
            <div class="relative z-10 w-10 h-10 rounded-full border border-[var(--color-saas)]/40 bg-[var(--bg-secondary)] flex items-center justify-center flex-shrink-0">
              <span class="text-[var(--color-saas)] text-xs font-bold">{s.step}</span>
            </div>
            <div class="flex-1 rounded-lg border border-[var(--border)] bg-[var(--bg-secondary)] p-4">
              <p class="text-[var(--text-primary)] font-medium text-sm">{s.title}</p>
              <p class="text-[var(--text-secondary)] text-xs mt-1">{s.result}</p>
              <!-- Mini progress bar -->
              <div class="mt-3 h-1 rounded-full bg-[var(--bg-tertiary)] overflow-hidden">
                <div class="h-full rounded-full bg-[var(--color-saas)]/60" style={`width: ${s.progress}%`}></div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </TierCard>

  <!-- Tier 3: Consulting -->
  <TierCard
    tier="consulting"
    label="AI-Powered Consulting"
    headline="What a security audit should feel like in 2026."
    story="For regulated industries, pre-acquisition due diligence, or enterprise compliance &mdash; you need more than a scan.<br /><br />We deploy AI-assisted analysis across your entire stack: source code, deployed artifacts, runtime behavior, infrastructure configuration. Our multi-level AI simulators probe your architecture the way a real attacker would &mdash; not one pattern at a time, but holistically.<br /><br />This is an AI-empowered red team. Human expertise directing AI capabilities. From code to cloud to runtime."
    features={[
      'AI-assisted analysis — not just human eyeballs on code',
      'Multi-level AI simulators against deployed infrastructure',
      'AI-powered red team exercises (not just automated scanning)',
      'Code → infrastructure → runtime → business logic coverage',
      'OWASP ASVS L2/L3 + CIS benchmarks + compliance mapping',
      'SOC 2, ISO 27001, PCI DSS evidence artifacts',
      'Remediation verification — we confirm the fixes work',
    ]}
    proof="Built by auditing a VARA-regulated crypto exchange. 87+ findings across 2 full iterations. This methodology is production-hardened, not theoretical."
    pricingHint="Startup $3,500  →  Standard $15K  →  Enterprise from $30K"
    ctaPrimary={{ text: 'Book a 30-min call →', href: url('/contact') }}
    ctaSecondary={{ text: 'See case study →', href: url('/case-study') }}
  >
    <!-- Analysis depth layers — stacked with perspective -->
    <div class="relative" style="perspective: 800px">
      <div class="space-y-2 text-sm" style="transform: rotateX(8deg)">
        {[
          { layer: '01', name: 'Source Code', desc: 'Static analysis', color: 'rgba(59,130,246,0.08)', border: 'rgba(59,130,246,0.15)' },
          { layer: '02', name: 'Dependencies', desc: 'Supply chain', color: 'rgba(59,130,246,0.12)', border: 'rgba(59,130,246,0.20)' },
          { layer: '03', name: 'Infrastructure', desc: 'Config & deploy', color: 'rgba(59,130,246,0.16)', border: 'rgba(59,130,246,0.25)' },
          { layer: '04', name: 'Runtime', desc: 'Dynamic behavior', color: 'rgba(59,130,246,0.22)', border: 'rgba(59,130,246,0.35)' },
          { layer: '05', name: 'Attack Simulation', desc: 'Red team', color: 'rgba(59,130,246,0.30)', border: 'rgba(59,130,246,0.50)' },
        ].map(l => (
          <div
            class="rounded-lg p-4 backdrop-blur-sm"
            style={`background: ${l.color}; border: 1px solid ${l.border}`}
          >
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <span class="font-mono text-[var(--color-consulting)] text-xs font-bold w-5">{l.layer}</span>
                <span class="text-[var(--text-primary)] font-medium text-sm">{l.name}</span>
              </div>
              <span class="text-[var(--text-muted)] text-xs font-mono">{l.desc}</span>
            </div>
          </div>
        ))}
      </div>
      <!-- Depth indicator -->
      <div class="flex items-center justify-center mt-4 gap-2">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent to-[var(--color-consulting)]/30"></div>
        <span class="text-xs font-mono text-[var(--color-consulting)]/60">deeper analysis &darr;</span>
        <div class="h-px flex-1 bg-gradient-to-l from-transparent to-[var(--color-consulting)]/30"></div>
      </div>
    </div>
  </TierCard>

  <!-- Flywheel -->
  <section class="py-24 md:py-32 fade-in-section">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight">Each tier feeds the next.</h2>
      <p class="text-lg text-[var(--text-secondary)] mt-6 leading-relaxed">
        Developers discover AI-Sec via the open-source tool. They find real issues.
        They try the platform for deeper analysis. Some need consulting for
        compliance or high-stakes launches. Consulting produces case studies that
        fuel content that drives more open-source adoption.
      </p>
      <!-- Flywheel SVG -->
      <div class="mt-12 flex justify-center">
        <svg viewBox="0 0 500 500" width="420" height="420" class="flywheel-svg">
          <!-- Circular track -->
          <circle cx="250" cy="250" r="170" fill="none" stroke="var(--border)" stroke-width="1" opacity="0.5" />

          <!-- Animated spinning arc -->
          <circle cx="250" cy="250" r="170" fill="none" stroke="url(#flywheel-gradient)" stroke-width="2" stroke-dasharray="180 888" stroke-linecap="round" class="flywheel-spin" />

          <!-- Gradient for spinning arc -->
          <defs>
            <linearGradient id="flywheel-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="var(--color-opensource)" />
              <stop offset="50%" stop-color="var(--color-saas)" />
              <stop offset="100%" stop-color="var(--color-consulting)" />
            </linearGradient>
          </defs>

          <!-- Node: Open Source (top) -->
          <g class="flywheel-node">
            <circle cx="250" cy="80" r="40" fill="var(--bg-secondary)" stroke="var(--color-opensource)" stroke-width="1.5" />
            <text x="250" y="76" text-anchor="middle" fill="var(--color-opensource)" font-size="11" font-family="monospace" font-weight="600">Open</text>
            <text x="250" y="90" text-anchor="middle" fill="var(--color-opensource)" font-size="11" font-family="monospace" font-weight="600">Source</text>
          </g>

          <!-- Node: Platform (right) -->
          <g class="flywheel-node">
            <circle cx="420" cy="250" r="40" fill="var(--bg-secondary)" stroke="var(--color-saas)" stroke-width="1.5" />
            <text x="420" y="253" text-anchor="middle" fill="var(--color-saas)" font-size="11" font-family="monospace" font-weight="600">Platform</text>
          </g>

          <!-- Node: Consulting (bottom) -->
          <g class="flywheel-node">
            <circle cx="250" cy="420" r="40" fill="var(--bg-secondary)" stroke="var(--color-consulting)" stroke-width="1.5" />
            <text x="250" y="416" text-anchor="middle" fill="var(--color-consulting)" font-size="11" font-family="monospace" font-weight="600">Consul-</text>
            <text x="250" y="430" text-anchor="middle" fill="var(--color-consulting)" font-size="11" font-family="monospace" font-weight="600">ting</text>
          </g>

          <!-- Node: Case Studies (left) -->
          <g class="flywheel-node">
            <circle cx="80" cy="250" r="40" fill="var(--bg-secondary)" stroke="var(--text-muted)" stroke-width="1" />
            <text x="80" y="246" text-anchor="middle" fill="var(--text-secondary)" font-size="10" font-family="monospace">Case</text>
            <text x="80" y="260" text-anchor="middle" fill="var(--text-secondary)" font-size="10" font-family="monospace">Studies</text>
          </g>

          <!-- Flow arrows (between nodes, along the circle) -->
          <!-- Top → Right -->
          <path d="M 285 90 Q 370 120 400 210" fill="none" stroke="var(--text-muted)" stroke-width="1" opacity="0.4" marker-end="url(#arrowhead)" />
          <!-- Right → Bottom -->
          <path d="M 410 290 Q 380 370 290 410" fill="none" stroke="var(--text-muted)" stroke-width="1" opacity="0.4" marker-end="url(#arrowhead)" />
          <!-- Bottom → Left -->
          <path d="M 210 410 Q 130 380 95 290" fill="none" stroke="var(--text-muted)" stroke-width="1" opacity="0.4" marker-end="url(#arrowhead)" />
          <!-- Left → Top -->
          <path d="M 90 210 Q 120 130 215 92" fill="none" stroke="var(--text-muted)" stroke-width="1" opacity="0.4" marker-end="url(#arrowhead)" />

          <defs>
            <marker id="arrowhead" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto" fill="var(--text-muted)" opacity="0.6">
              <polygon points="0 0, 8 3, 0 6" />
            </marker>
          </defs>

          <!-- Center label -->
          <text x="250" y="245" text-anchor="middle" fill="var(--text-muted)" font-size="11" font-family="monospace" opacity="0.6">everyone</text>
          <text x="250" y="260" text-anchor="middle" fill="var(--text-muted)" font-size="11" font-family="monospace" opacity="0.6">gets safer</text>
        </svg>
      </div>
    </div>
  </section>

  <!-- Proof: Real findings -->
  <section class="py-24 md:py-32 bg-[var(--bg-secondary)] fade-in-section">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-center mb-4">
        Don't take our word for it. Read the audits.
      </h2>
      <p class="text-[var(--text-secondary)] text-center max-w-2xl mx-auto mb-12">
        We audited 3 popular open-source projects and published the results. 98 findings total.
      </p>
      <div class="grid md:grid-cols-3 gap-6">
        <Card>
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold">maybe-finance</h3>
            <span class="text-xs font-mono text-[var(--text-muted)]">35K &#9733;</span>
          </div>
          <p class="text-sm font-medium text-[var(--color-error)] mb-3">
            OTP secrets and Plaid tokens stored in plaintext
          </p>
          <p class="text-xs font-mono text-[var(--text-muted)]">5 critical &middot; 6 high</p>
        </Card>
        <Card>
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold">Documenso</h3>
            <span class="text-xs font-mono text-[var(--text-muted)]">8K &#9733;</span>
          </div>
          <p class="text-sm font-medium text-[var(--color-error)] mb-3">
            Encryption key validation commented out in production
          </p>
          <p class="text-xs font-mono text-[var(--text-muted)]">1 critical &middot; 3 high</p>
        </Card>
        <Card>
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold">Hoppscotch</h3>
            <span class="text-xs font-mono text-[var(--text-muted)]">65K &#9733;</span>
          </div>
          <p class="text-sm font-medium text-[var(--color-error)] mb-3">
            IDOR + unauthenticated infrastructure takeover
          </p>
          <p class="text-xs font-mono text-[var(--text-muted)]">3 high &middot; 3 medium</p>
        </Card>
      </div>
      <div class="text-center mt-10">
        <a href={url('/case-study')} class="text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors font-medium">
          Read full case studies &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Founder -->
  <section class="py-16 md:py-20 fade-in-section">
    <div class="max-w-5xl mx-auto px-6">
      <div class="rounded-xl border border-[var(--border)] bg-[var(--bg-secondary)] p-8 md:p-10 flex flex-col md:flex-row items-start gap-8">
        <div class="flex-1">
          <p class="text-xs font-mono text-[var(--text-muted)] uppercase tracking-wider mb-3">Built by</p>
          <h3 class="text-xl font-semibold">Sergey Kovalev</h3>
          <p class="text-sm text-[var(--text-secondary)] mt-1">CTO at a VARA-regulated crypto exchange</p>
          <p class="text-sm text-[var(--text-secondary)] mt-4 leading-relaxed max-w-lg">
            AI-Sec wasn't built by a security vendor. It was built by someone who runs engineering, ships product, and needed to audit his own code. 87+ findings across 2 full iterations on a production fintech platform.
          </p>
        </div>
        <div class="flex md:flex-col gap-4 md:gap-3 md:pt-8">
          <a href="https://www.linkedin.com/in/skovalev/" target="_blank" rel="noopener noreferrer" class="text-sm text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors">LinkedIn &rarr;</a>
          <a href="https://github.com/sergey-ko/ai-sec" target="_blank" rel="noopener noreferrer" class="text-sm text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors">GitHub &rarr;</a>
          <a href="https://youtube.com/@skovalev" target="_blank" rel="noopener noreferrer" class="text-sm text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors">YouTube &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-24 md:py-32" style="background: var(--gradient-hero)">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-center mb-12" style="font-family: 'Instrument Serif', Georgia, serif">
        Your code is live. Is it secure?
      </h2>
      <div class="grid md:grid-cols-2 gap-12 max-w-3xl mx-auto">
        <div class="text-center md:text-left">
          <h3 class="text-xl font-semibold mb-3">Start free.</h3>
          <p class="text-[var(--text-secondary)] mb-6">
            Clone the open-source tool and run /audit right now. No account needed.
          </p>
          <a href="https://github.com/sergey-ko/ai-sec" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-6 py-3 rounded-lg font-medium border border-[var(--border)] text-[var(--text-primary)] hover:border-[var(--border-hover)] transition-colors">
            View on GitHub &rarr;
          </a>
        </div>
        <div class="text-center md:text-left">
          <h3 class="text-xl font-semibold mb-3">Talk to us.</h3>
          <p class="text-[var(--text-secondary)] mb-6">
            Book a 30-minute call. We'll scope what you actually need. No sales pitch &mdash; just answers.
          </p>
          <a href={url('/contact')} class="inline-flex items-center px-6 py-3 rounded-lg font-medium bg-white text-black hover:bg-white/90 transition-colors">
            Book a call &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer productName="AI-Sec" links={footerLinks} />

  <script>
    // Scroll-triggered fade-in
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );
    document.querySelectorAll('.fade-in-section').forEach((el) => observer.observe(el));
  </script>
</Base>
