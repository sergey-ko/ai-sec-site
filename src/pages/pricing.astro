---
import Base from '@fce/shared/layouts/Base.astro';
import Nav from '@fce/shared/components/Nav.astro';
import Badge from '@fce/shared/components/Badge.astro';
import ComparisonTable from '@fce/shared/components/ComparisonTable.astro';
import Footer from '@fce/shared/components/Footer.astro';
import FAQ from '../components/FAQ.astro';
import { navLinks, footerLinks, navCta, url } from '../lib/links';
import '../styles/theme.css';

const comparisonColumns = ['AI-Sec', 'Snyk / Semgrep', 'Traditional Pentest'];
const comparisonRows = [
  { label: 'Architecture reasoning', values: ['✓', '✗', '✓'] },
  { label: 'IDOR / broken auth detection', values: ['✓', '✗', '✓'] },
  { label: 'Business logic analysis', values: ['✓', '✗', '✓'] },
  { label: 'OWASP ASVS L2 methodology', values: ['✓', 'Partial', 'Varies'] },
  { label: 'CVSS-scored findings', values: ['✓', '✓', '✓'] },
  { label: 'Fix guidance with code', values: ['✓', '✗', 'Sometimes'] },
  { label: 'Turnaround', values: ['Minutes → weeks', 'Minutes', '4-6 weeks'] },
  { label: 'Price', values: ['Free → $30K+', 'Free → $98/mo', '$15K+'] },
  { label: 'Full codebase analysis', values: ['✓', 'File-by-file', 'Black-box'] },
];

const faqItems = [
  {
    question: 'What languages and frameworks do you support?',
    answer: 'Any language and framework in a Git repository. TypeScript, Python, Go, Rust, Java, Ruby, PHP, C#, and more. If you can commit it, we can audit it.',
  },
  {
    question: 'How is this different from Snyk or Semgrep?',
    answer: 'They match known patterns — great for CVEs and injection templates. AI-Sec reasons about your architecture holistically: IDORs, broken auth flows, business logic flaws, trust boundary violations. The difference between a spell checker and someone who reads your essay.',
  },
  {
    question: 'Can I start free and upgrade later?',
    answer: "Yes. Most users start with the free tool, see real findings, then upgrade to consulting for deeper analysis. The free tool finds ~60-70% of what the full audit catches.",
  },
  {
    question: 'Is my code safe? Who has access?',
    answer: 'Code is processed in isolated environments. We never store source code after the audit. Only findings and metadata are retained. NDA available. Enterprise clients get on-premise deployment.',
  },
  {
    question: "What's in the report?",
    answer: 'Every finding: CVSS severity, OWASP category, CWE identifier, description, reproduction steps, fix guidance with code examples. Prioritized by risk.',
  },
  {
    question: 'Can I use this for SOC 2 / ISO 27001?',
    answer: 'Yes. Standard and Enterprise consulting produce compliance-ready reports mapped to SOC 2, ISO 27001, and PCI DSS. Many clients use our reports as compliance evidence.',
  },
  {
    question: 'What if you don\'t find anything?',
    answer: "Every codebase has findings. We found 81 across 3 projects with 108K+ GitHub stars. If we genuinely find nothing above informational, you get a clean report for investors or regulators.",
  },
];
---

<Base
  title="Pricing — AI-Sec"
  description="Free open-source tool, $299/mo continuous platform (coming soon), consulting from $3,500. AI security at every scale."
>
  <Nav logo="AI-Sec" homeHref={url('/')} links={navLinks} ctaText={navCta.text} ctaHref={navCta.href} />

  <!-- Hero -->
  <section class="py-24 md:py-32">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-semibold leading-tight tracking-tight">
        From free to enterprise-grade.
      </h1>
      <p class="text-lg sm:text-xl text-[var(--text-secondary)] mt-6 max-w-2xl mx-auto leading-relaxed">
        Same methodology at every tier. Automation when you can. Experts when you must.
      </p>
    </div>
  </section>

  <!-- Three-column pricing -->
  <section class="pb-24 md:pb-32">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-6">

        <!-- Open Source -->
        <div class="rounded-xl p-8 border border-[var(--color-opensource)]/30 bg-[var(--bg-secondary)] flex flex-col">
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-[var(--color-opensource)]">Open Source</span>
          <p class="text-3xl font-bold mt-3 text-[var(--text-primary)]">Free</p>
          <p class="text-sm text-[var(--text-secondary)] mt-2 leading-relaxed">
            Our gift to the ecosystem. Clone it, run it, ship safer code.
          </p>
          <ul class="mt-6 space-y-3 flex-1">
            {[
              'Run /audit in your IDE',
              '5 specialized agents',
              'OWASP Top 10 coverage',
              '~60-70% of full audit coverage',
              'No account needed',
              'Your code stays on your machine',
            ].map(f => (
              <li class="flex items-start gap-2 text-sm text-[var(--text-secondary)]">
                <span class="text-[var(--color-opensource)] mt-0.5">&#10003;</span>
                {f}
              </li>
            ))}
          </ul>
          <a href="https://github.com/sergey-ko/ai-sec" target="_blank" rel="noopener noreferrer" class="block text-center mt-8 px-5 py-3 rounded-lg font-medium text-sm border border-[var(--color-opensource)]/30 text-[var(--color-opensource)] hover:border-[var(--color-opensource)]/60 transition-colors">
            View on GitHub &rarr;
          </a>
        </div>

        <!-- SaaS Platform — Coming Soon -->
        <div class="rounded-xl p-8 border border-[var(--color-saas)]/30 bg-[var(--bg-secondary)] flex flex-col relative">
          <Badge text="Coming Soon" />
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-[var(--color-saas)] mt-4 block">Platform</span>
          <p class="text-3xl font-bold mt-3 text-[var(--text-primary)]">$299<span class="text-lg font-normal text-[var(--text-muted)]">/mo</span></p>
          <p class="text-sm text-[var(--text-secondary)] mt-2 leading-relaxed">
            The free tool scans. The platform hunts. Multi-step hardened workflows, continuously.
          </p>
          <ul class="mt-6 space-y-3 flex-1">
            {[
              'Multi-step audit workflows',
              'Attack path chaining',
              'Scan on every PR',
              'Fix verification &mdash; confirm patches work',
              'Team dashboard + trend tracking',
              'CI/CD integration',
              'Slack/email alerts',
            ].map(f => (
              <li class="flex items-start gap-2 text-sm text-[var(--text-secondary)]">
                <span class="text-[var(--color-saas)] mt-0.5">&#10003;</span>
                <span set:html={f} />
              </li>
            ))}
          </ul>
          <a href={url('/free-scan')} class="block text-center mt-8 px-5 py-3 rounded-lg font-medium text-sm border border-[var(--color-saas)]/30 text-[var(--color-saas)] hover:border-[var(--color-saas)]/60 transition-colors">
            Join Waitlist &rarr;
          </a>
        </div>

        <!-- Consulting -->
        <div class="rounded-xl p-8 border border-[var(--color-consulting)]/30 bg-[var(--bg-secondary)] flex flex-col">
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-[var(--color-consulting)]">Consulting</span>
          <p class="text-3xl font-bold mt-3 text-[var(--text-primary)]">From $3,500</p>
          <p class="text-sm text-[var(--text-secondary)] mt-2 leading-relaxed">
            Human + AI. Red team, simulators, compliance. From code to cloud to runtime.
          </p>
          <ul class="mt-6 space-y-3 flex-1">
            {[
              'AI-powered red team exercises',
              'Multi-level AI simulators',
              'Code → infrastructure → runtime',
              'OWASP ASVS L2/L3 methodology',
              'Compliance mapping (SOC 2, ISO, PCI)',
              'Expert review + remediation verification',
            ].map(f => (
              <li class="flex items-start gap-2 text-sm text-[var(--text-secondary)]">
                <span class="text-[var(--color-consulting)] mt-0.5">&#10003;</span>
                {f}
              </li>
            ))}
          </ul>
          <a href={url('/contact')} class="block text-center mt-8 px-5 py-3 rounded-lg font-medium text-sm bg-[var(--color-consulting)] text-white hover:opacity-90 transition-opacity">
            Book a Call &rarr;
          </a>
        </div>
      </div>

      <div class="mt-8 text-center">
        <p class="text-sm text-[var(--text-muted)]">
          Open-source tool and consulting available now. SaaS platform launching soon.
        </p>
      </div>
    </div>
  </section>

  <!-- Consulting detail -->
  <section class="py-24 md:py-32 bg-[var(--bg-secondary)]">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight mb-4">Consulting engagements.</h2>
      <p class="text-[var(--text-secondary)] mb-12 max-w-2xl">When automation isn't enough. Every engagement is scoped on a call &mdash; these are starting points.</p>

      <div class="grid md:grid-cols-3 gap-6">
        <!-- Startup -->
        <div class="rounded-xl p-8 border-2 border-[var(--color-consulting)] bg-[var(--bg-primary)] relative flex flex-col">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[var(--color-consulting)] text-white text-xs font-bold px-3 py-1 rounded-full">MOST POPULAR</span>
          <h3 class="text-xl font-semibold">Startup</h3>
          <p class="text-3xl font-bold mt-2 text-[var(--color-consulting)]">$3,500</p>
          <p class="text-xs font-mono text-[var(--text-muted)] mt-1">2-3 days</p>
          <ul class="mt-6 space-y-3 flex-1">
            {['Full ASVS L2 audit', '2hr expert review', 'All findings with CVSS scores', 'Fix guidance for every finding', 'PDF + Markdown report'].map(f => (
              <li class="flex items-start gap-2 text-sm text-[var(--text-secondary)]">
                <span class="text-[var(--color-consulting)] mt-0.5 text-xs">&#9679;</span>
                {f}
              </li>
            ))}
          </ul>
          <p class="text-xs text-[var(--text-muted)] mt-6 italic">Best for: MVPs, vibecoded apps, pre-launch, investor due diligence</p>
          <a href={url('/contact')} class="block text-center mt-4 px-5 py-3 rounded-lg font-medium text-sm bg-[var(--color-consulting)] text-white hover:opacity-90 transition-opacity">
            Get Started &rarr;
          </a>
        </div>

        <!-- Standard -->
        <div class="rounded-xl p-8 border border-[var(--border)] bg-[var(--bg-primary)] flex flex-col">
          <h3 class="text-xl font-semibold">Standard</h3>
          <p class="text-3xl font-bold mt-2 text-[var(--color-consulting)]">$15,000</p>
          <p class="text-xs font-mono text-[var(--text-muted)] mt-1">1-2 weeks</p>
          <p class="text-xs text-[var(--text-muted)] mt-3 italic">Everything in Startup, plus:</p>
          <ul class="mt-4 space-y-3 flex-1">
            {['Complete ASVS L2 (286 controls)', 'Active testing of critical flows', 'Compliance-ready report', '30-day re-test window'].map(f => (
              <li class="flex items-start gap-2 text-sm text-[var(--text-secondary)]">
                <span class="text-[var(--color-consulting)] mt-0.5 text-xs">&#9679;</span>
                {f}
              </li>
            ))}
          </ul>
          <p class="text-xs text-[var(--text-muted)] mt-6 italic">Best for: Series A+, SOC 2 evidence, enterprise sales</p>
          <a href={url('/contact')} class="block text-center mt-4 px-5 py-3 rounded-lg font-medium text-sm border border-[var(--border)] text-[var(--text-primary)] hover:border-[var(--border-hover)] transition-colors">
            Book a Call &rarr;
          </a>
        </div>

        <!-- Enterprise -->
        <div class="rounded-xl p-8 border border-[var(--border)] bg-[var(--bg-primary)] flex flex-col">
          <h3 class="text-xl font-semibold">Enterprise</h3>
          <p class="text-3xl font-bold mt-2 text-[var(--color-consulting)]">From $30K</p>
          <p class="text-xs font-mono text-[var(--text-muted)] mt-1">2-4 weeks</p>
          <p class="text-xs text-[var(--text-muted)] mt-3 italic">Everything in Standard, plus:</p>
          <ul class="mt-4 space-y-3 flex-1">
            {['ASVS L2/L3 coverage', 'CIS + SOC 2 + ISO 27001 mapping', 'Dedicated security engineer', '90-day re-test window'].map(f => (
              <li class="flex items-start gap-2 text-sm text-[var(--text-secondary)]">
                <span class="text-[var(--color-consulting)] mt-0.5 text-xs">&#9679;</span>
                {f}
              </li>
            ))}
          </ul>
          <p class="text-xs text-[var(--text-muted)] mt-6 italic">Best for: fintech, crypto, healthcare, regulated industries</p>
          <a href={url('/contact')} class="block text-center mt-4 px-5 py-3 rounded-lg font-medium text-sm border border-[var(--border)] text-[var(--text-primary)] hover:border-[var(--border-hover)] transition-colors">
            Contact Us &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <ComparisonTable
    headline="How we compare."
    columns={comparisonColumns}
    rows={comparisonRows}
  />
  <div class="max-w-4xl mx-auto px-6 -mt-16 mb-24">
    <p class="text-sm text-[var(--text-muted)] text-center leading-relaxed">
      Snyk and Semgrep are excellent for known vulnerability patterns. AI-Sec catches what they can't: architectural and logic flaws. Many teams run both.
    </p>
  </div>

  <!-- FAQ -->
  <FAQ headline="Questions & answers." items={faqItems} />

  <!-- Bottom CTA -->
  <section class="py-24 md:py-32" style="background: var(--gradient-hero)">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight">Not sure where to start?</h2>
      <p class="text-[var(--text-secondary)] mt-4 text-lg">
        Book a 30-minute call. We'll tell you honestly what you need &mdash; even if the answer is "just use the free tool."
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a href={url('/contact')} class="inline-flex items-center justify-center px-6 py-3 rounded-lg font-medium bg-white text-black hover:bg-white/90 transition-colors">
          Book a call &rarr;
        </a>
        <a href="https://github.com/sergey-ko/ai-sec" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-6 py-3 rounded-lg font-medium border border-[var(--border)] text-[var(--text-primary)] hover:border-[var(--border-hover)] transition-colors">
          Or just clone the repo &mdash; it's free
        </a>
      </div>
    </div>
  </section>

  <Footer productName="AI-Sec" links={footerLinks} />
</Base>
