---
import Base from '@fce/shared/layouts/Base.astro';
import Nav from '@fce/shared/components/Nav.astro';
import Badge from '@fce/shared/components/Badge.astro';
import Card from '@fce/shared/components/Card.astro';
import ComparisonTable from '@fce/shared/components/ComparisonTable.astro';
import Button from '@fce/shared/components/Button.astro';
import Footer from '@fce/shared/components/Footer.astro';
import FAQ from '../components/FAQ.astro';
import '../styles/theme.css';

const navLinks = [
  { text: 'Free Scan', href: '/free-scan' },
  { text: 'Open Source', href: '/open-source' },
  { text: 'Pricing', href: '/pricing' },
  { text: 'Case Study', href: '/case-study' },
  { text: 'Contact', href: '/contact' },
];

const footerLinks = [
  { text: 'Free Scan', href: '/free-scan' },
  { text: 'Pricing', href: '/pricing' },
  { text: 'Case Study', href: '/case-study' },
  { text: 'Contact', href: '/contact' },
  { text: 'GitHub', href: 'https://github.com/sergey-ko' },
];

const comparisonColumns = ['AI-Sec Startup Quick', 'Snyk (Team)', 'Manual Pentest'];
const comparisonRows = [
  { label: 'Price', values: ['$2-5K', '$0-98/mo', '$15-50K+'] },
  { label: 'Turnaround', values: ['2-3 days', 'Real-time', '4-6 weeks'] },
  { label: 'Architectural reasoning', values: ['&#10003;', '&#10007;', '&#10003;'] },
  { label: 'IDOR / auth flow bugs', values: ['&#10003;', '&#10007;', '&#10003;'] },
  { label: 'Business logic flaws', values: ['&#10003;', '&#10007;', '&#10003;'] },
  { label: 'Known CVE detection', values: ['&#10003;', '&#10003;', '&#10003;'] },
  { label: 'OWASP ASVS methodology', values: ['&#10003;', 'Partial', 'Varies'] },
  { label: 'Fix guidance with code', values: ['&#10003;', '&#10007;', 'Sometimes'] },
  { label: 'Compliance mapping', values: ['Standard+', '&#10007;', 'Enterprise only'] },
  { label: 'Expert review', values: ['&#10003; (included)', '&#10007;', '&#10003;'] },
];

const faqItems = [
  {
    question: 'Can I start with Startup Quick and upgrade later?',
    answer: "Absolutely. Many clients start with a Startup Quick to understand their risk profile, then upgrade to Standard when they need compliance evidence or deeper analysis. We apply a portion of your Startup Quick fee toward the Standard tier.",
  },
  {
    question: 'Do you offer discounts for startups or open-source projects?',
    answer: 'Yes. We offer reduced rates for pre-seed startups and free quick-scans for significant open-source projects. Contact us to discuss.',
  },
  {
    question: 'What if I need something between tiers?',
    answer: "Every engagement is scoped to your needs. The tiers are starting points. Book a call and we'll put together a custom scope that fits your budget and requirements.",
  },
  {
    question: 'Is there a money-back guarantee?',
    answer: "If we fail to deliver findings that you find actionable and valuable, we'll refund your fee. We've never had to do this \u2014 every codebase has findings.",
  },
];
---

<Base
  title="Pricing \u2014 AI-Sec"
  description="Enterprise-grade security audits from $2K. Three tiers: Startup Quick ($2-5K), Standard ($10-20K), Enterprise ($20-50K+). Self-service scans coming soon."
>
  <Nav logo="AI-Sec" links={navLinks} ctaText="Get Free Scan" ctaHref="/free-scan" />

  <!-- Hero -->
  <section class="py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold leading-tight">
        Enterprise security.<br />Startup pricing.
      </h1>
      <p class="text-lg sm:text-xl text-[var(--text-secondary)] mt-6 max-w-3xl mx-auto leading-relaxed">
        Professional OWASP ASVS L2 security audits starting at $2K. No six-figure contracts. No six-week timelines. Just actionable findings you can fix today.
      </p>
    </div>
  </section>

  <!-- Consulting Tiers -->
  <section class="py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-6">
        <!-- Startup Quick -->
        <div class="rounded-xl p-6 md:p-8 border border-[var(--border)] bg-[var(--bg-secondary)]">
          <h3 class="text-lg font-semibold">Startup Quick</h3>
          <p class="text-3xl font-bold mt-2 text-[var(--accent-primary)]">$2-5K</p>
          <p class="text-sm text-[var(--text-secondary)] mt-1">Best for MVPs and vibecoded apps</p>
          <p class="text-xs text-[var(--text-muted)] mt-2 font-mono">Timeline: 2-3 business days</p>
          <ul class="mt-6 space-y-3">
            {[
              'Automated AI security audit',
              '2-hour expert review',
              'OWASP Top 10 coverage',
              'Prioritized findings with severity scores',
              'Fix guidance for all findings',
              'PDF + Markdown report',
            ].map(f => (
              <li class="flex items-start gap-2 text-sm text-[var(--text-secondary)]">
                <span class="text-[var(--accent-primary)] mt-0.5">&#10003;</span>
                {f}
              </li>
            ))}
          </ul>
          <p class="text-xs text-[var(--text-muted)] mt-6">
            Best for: Solo developers, vibecoder projects, early-stage startups, freelancers delivering to clients.
          </p>
          <a
            href="/contact"
            class="block text-center mt-6 px-6 py-3 rounded-lg font-medium border border-[var(--border)] text-[var(--text-primary)] hover:border-[var(--border-hover)] transition-colors"
          >
            Book a Call &rarr;
          </a>
        </div>

        <!-- Standard (Highlighted) -->
        <div class="rounded-xl p-6 md:p-8 border-2 border-[var(--accent-primary)] bg-[var(--bg-secondary)] relative">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[var(--accent-primary)] text-[var(--accent-btn-text)] text-xs font-bold px-4 py-1 rounded-full">
            MOST POPULAR
          </span>
          <h3 class="text-lg font-semibold">Standard</h3>
          <p class="text-3xl font-bold mt-2 text-[var(--accent-primary)]">$10-20K</p>
          <p class="text-sm text-[var(--text-secondary)] mt-1">Full compliance-ready audit</p>
          <p class="text-xs text-[var(--text-muted)] mt-2 font-mono">Timeline: 1-2 weeks</p>
          <p class="text-xs text-[var(--text-muted)] mt-3 italic">Everything in Startup Quick, plus:</p>
          <ul class="mt-4 space-y-3">
            {[
              'Complete ASVS L2 checklist (286 controls)',
              'Active testing of critical flows',
              'CVSS-scored findings with reproduction steps',
              'Code-level fix examples',
              'Compliance-ready report format',
              '1 hour remediation consultation',
              '30-day re-test of fixed findings',
            ].map(f => (
              <li class="flex items-start gap-2 text-sm text-[var(--text-secondary)]">
                <span class="text-[var(--accent-primary)] mt-0.5">&#10003;</span>
                {f}
              </li>
            ))}
          </ul>
          <p class="text-xs text-[var(--text-muted)] mt-6">
            Best for: Seed/Series A startups, teams needing SOC 2 evidence, enterprise sales requirements.
          </p>
          <a
            href="/contact"
            class="block text-center mt-6 px-6 py-3 rounded-lg font-medium bg-[var(--accent-primary)] text-[var(--accent-btn-text)] hover:opacity-90 transition-opacity"
          >
            Book a Call &rarr;
          </a>
        </div>

        <!-- Enterprise -->
        <div class="rounded-xl p-6 md:p-8 border border-[var(--border)] bg-[var(--bg-secondary)]">
          <h3 class="text-lg font-semibold">Enterprise</h3>
          <p class="text-3xl font-bold mt-2 text-[var(--accent-primary)]">$20-50K+</p>
          <p class="text-sm text-[var(--text-secondary)] mt-1">For regulated industries</p>
          <p class="text-xs text-[var(--text-muted)] mt-2 font-mono">Timeline: 2-4 weeks</p>
          <p class="text-xs text-[var(--text-muted)] mt-3 italic">Everything in Standard, plus:</p>
          <ul class="mt-4 space-y-3">
            {[
              'ASVS L2/L3 coverage',
              'CIS benchmark assessment',
              'SOC 2 Trust Service Criteria mapping',
              'ISO 27001 Annex A mapping',
              'PCI DSS mapping (if applicable)',
              'Dedicated security engineer',
              'Executive summary for board/investors',
              '90-day re-test window',
              'On-call support during remediation',
            ].map(f => (
              <li class="flex items-start gap-2 text-sm text-[var(--text-secondary)]">
                <span class="text-[var(--accent-primary)] mt-0.5">&#10003;</span>
                {f}
              </li>
            ))}
          </ul>
          <p class="text-xs text-[var(--text-muted)] mt-6">
            Best for: Fintech, crypto, healthcare, any regulated industry. Companies preparing for SOC 2 or ISO certification.
          </p>
          <a
            href="/contact"
            class="block text-center mt-6 px-6 py-3 rounded-lg font-medium border border-[var(--border)] text-[var(--text-primary)] hover:border-[var(--border-hover)] transition-colors"
          >
            Contact Us &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Self-Service Coming Soon -->
  <section class="py-24 md:py-32">
    <div class="max-w-3xl mx-auto px-6">
      <Card class="relative opacity-90">
        <Badge text="Coming Soon \u2014 Q2 2026" class="mb-6" />
        <h2 class="text-2xl md:text-3xl font-bold mb-4">Self-service scans. From $50.</h2>
        <p class="text-[var(--text-secondary)] leading-relaxed mb-6">
          Run AI-Sec audits on demand &mdash; no call, no waiting. Submit a repo, get results in minutes. Perfect for continuous security checks during development.
        </p>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse text-sm">
            <thead>
              <tr>
                <th class="text-left p-3 text-[var(--text-muted)] font-medium border-b border-[var(--border)]">Plan</th>
                <th class="text-left p-3 text-[var(--text-muted)] font-medium border-b border-[var(--border)]">Price</th>
                <th class="text-left p-3 text-[var(--text-muted)] font-medium border-b border-[var(--border)]">What you get</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-[var(--border)]">
                <td class="p-3 text-[var(--text-primary)]">Quick Scan</td>
                <td class="p-3 text-[var(--text-secondary)]">$50</td>
                <td class="p-3 text-[var(--text-secondary)]">OWASP Top 10 scan, severity ratings</td>
              </tr>
              <tr class="border-b border-[var(--border)]">
                <td class="p-3 text-[var(--text-primary)]">Full ASVS</td>
                <td class="p-3 text-[var(--text-secondary)]">$150-200</td>
                <td class="p-3 text-[var(--text-secondary)]">Complete ASVS L2 analysis</td>
              </tr>
              <tr class="border-b border-[var(--border)]">
                <td class="p-3 text-[var(--text-primary)]">Monthly Pro</td>
                <td class="p-3 text-[var(--text-secondary)]">$99/mo</td>
                <td class="p-3 text-[var(--text-secondary)]">5 full scans/month + monitoring</td>
              </tr>
              <tr class="border-b border-[var(--border)]">
                <td class="p-3 text-[var(--text-primary)]">Monthly Team</td>
                <td class="p-3 text-[var(--text-secondary)]">$299/mo</td>
                <td class="p-3 text-[var(--text-secondary)]">20 scans + CI/CD integration</td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="mt-6">
          <Button href="/free-scan" variant="secondary" size="md">Join the Waitlist &rarr;</Button>
        </div>
      </Card>
    </div>
  </section>

  <!-- Comparison vs Alternatives -->
  <ComparisonTable
    headline="How we compare."
    columns={comparisonColumns}
    rows={comparisonRows}
  />
  <div class="max-w-4xl mx-auto px-6 -mt-16 mb-24">
    <p class="text-sm text-[var(--text-muted)] text-center leading-relaxed">
      Snyk and Semgrep are excellent for what they do &mdash; catching known vulnerabilities in dependencies and common patterns. AI-Sec catches what they can't: the architectural and logic flaws that pattern-matching tools miss. Many of our clients run both.
    </p>
  </div>

  <!-- Pricing FAQ -->
  <FAQ headline="Pricing questions." items={faqItems} />

  <!-- Bottom CTA -->
  <section class="py-24 md:py-32" style={`background: var(--gradient-hero)`}>
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold">Ready to find out what's in your code?</h2>
      <p class="text-[var(--text-secondary)] mt-4 text-lg">
        Book a 15-minute scoping call. We'll tell you which tier fits and what to expect. No commitment required.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <Button href="/contact" variant="primary" size="lg">Book a Call &rarr;</Button>
        <Button href="/free-scan" variant="secondary" size="lg">Get Free Scan</Button>
      </div>
    </div>
  </section>

  <Footer productName="AI-Sec" links={footerLinks} />
</Base>
