---
import { url } from '../lib/links';
---

<div class="rounded-xl border border-[var(--border)] bg-[var(--bg-secondary)] p-6 md:p-8">
  <h3 class="text-xl font-bold mb-6">Start your free audit</h3>
  <form id="audit-form" class="space-y-4">
    <div>
      <label for="email" class="block text-sm font-medium text-[var(--text-secondary)] mb-1">Email address *</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="w-full px-4 py-3 rounded-lg bg-[var(--bg-tertiary)] border border-[var(--border)] text-[var(--text-primary)] placeholder:text-[var(--text-muted)] focus:outline-none focus:border-[var(--accent-primary)] transition-colors"
        placeholder="you@company.com"
      />
    </div>
    <div>
      <label for="repo" class="block text-sm font-medium text-[var(--text-secondary)] mb-1">GitHub repository URL *</label>
      <input
        type="url"
        id="repo"
        name="repo"
        required
        class="w-full px-4 py-3 rounded-lg bg-[var(--bg-tertiary)] border border-[var(--border)] text-[var(--text-primary)] placeholder:text-[var(--text-muted)] focus:outline-none focus:border-[var(--accent-primary)] transition-colors"
        placeholder="https://github.com/you/repo"
      />
    </div>
    <div>
      <label for="company" class="block text-sm font-medium text-[var(--text-secondary)] mb-1">Company name</label>
      <input
        type="text"
        id="company"
        name="company"
        class="w-full px-4 py-3 rounded-lg bg-[var(--bg-tertiary)] border border-[var(--border)] text-[var(--text-primary)] placeholder:text-[var(--text-muted)] focus:outline-none focus:border-[var(--accent-primary)] transition-colors"
        placeholder="Acme Inc."
      />
    </div>
    <div>
      <label for="concern" class="block text-sm font-medium text-[var(--text-secondary)] mb-1">What's your main concern?</label>
      <select
        id="concern"
        name="concern"
        class="w-full px-4 py-3 rounded-lg bg-[var(--bg-tertiary)] border border-[var(--border)] text-[var(--text-secondary)] focus:outline-none focus:border-[var(--accent-primary)] transition-colors"
      >
        <option value="">Select one...</option>
        <option value="ai-tools">I built with AI tools and want to check security</option>
        <option value="enterprise">Enterprise customer is asking for a security audit</option>
        <option value="compliance">Preparing for SOC 2 / compliance</option>
        <option value="general">General security review</option>
        <option value="other">Other</option>
      </select>
    </div>
    <button
      type="submit"
      class="w-full px-6 py-3 rounded-lg bg-[var(--accent-primary)] text-[var(--accent-btn-text)] font-semibold text-lg hover:opacity-90 transition-opacity"
    >
      Run Free Audit &rarr;
    </button>
    <p class="text-xs text-[var(--text-muted)] leading-relaxed">
      We'll email your results within 24 hours. Your code is processed in a secure environment and never stored after analysis. By submitting, you agree to our Privacy Policy.
    </p>
  </form>
  <div id="audit-success" class="hidden text-center py-8">
    <div class="text-[var(--accent-primary)] text-4xl mb-4">&#10003;</div>
    <h3 class="text-xl font-bold mb-2">Audit submitted!</h3>
    <p class="text-[var(--text-secondary)] mb-6">
      We're analyzing your repository now. You'll receive your results via email within 24 hours.
    </p>
    <a href={url('/case-study')} class="text-[var(--accent-primary)] hover:underline">
      Read the case study &rarr;
    </a>
  </div>
</div>

<script>
  const form = document.getElementById('audit-form') as HTMLFormElement;
  const success = document.getElementById('audit-success');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    // In production, POST to /api/free-audit
    form.classList.add('hidden');
    success?.classList.remove('hidden');
  });
</script>
